{
    "name": "get-jj",
    "version": "1.0.0",
    "description": "JJ: your helpful jira buddy — a fast, friendly CLI for Jira Cloud",
    "type": "module",
    "bin": {
        "jj": "dist/cli.js"
    },
    "files": [
        "dist",
        "skills"
    ],
    "keywords": [
        "jira",
        "cli",
        "sprint",
        "kanban",
        "board",
        "markdown",
        "agile",
        "scrum",
        "project-management"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/jasperfurniss/jj-cli.git"
    },
    "author": "Jasper Furniss",
    "license": "MIT",
    "scripts": {
        "build": "tsup src/cli.ts --format esm --dts --clean",
        "dev": "tsx src/cli.ts",
        "test": "vitest run",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@clack/prompts": "^0.9.1",
        "ink": "^6.8.0",
        "picocolors": "^1.1.1",
        "react": "^19.2.4",
        "terminal-image": "^4.2.0",
        "turndown": "^7.2.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/react": "^19.2.14",
        "@types/turndown": "^5.0.5",
        "tsup": "^8.3.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "vitest": "^4.1.4"
    }
}
