{
    "name": "jj-cli",
    "version": "1.0.0",
    "description": "Interactive CLI to convert Jira stories to Markdown",
    "type": "module",
    "bin": {
        "jj": "./dist/cli.js"
    },
    "scripts": {
        "build": "tsup src/cli.ts --format esm --dts --clean",
        "dev": "tsx src/cli.ts",
        "test": "vitest run"
    },
    "dependencies": {
        "@clack/prompts": "^0.9.1",
        "ink": "^6.8.0",
        "picocolors": "^1.1.1",
        "react": "^19.2.4",
        "terminal-image": "^4.2.0",
        "turndown": "^7.2.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@types/react": "^19.2.14",
        "@types/turndown": "^5.0.5",
        "tsup": "^8.3.0",
        "tsx": "^4.19.0",
        "typescript": "^5.6.0",
        "vitest": "^4.1.4"
    }
}
